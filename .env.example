# Supabase (shared framework project) — required for online multiplayer.
# These are server-side secrets set in the Cloudflare Pages dashboard /
# `wrangler pages secret put`, NOT baked into the client bundle.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend turn-reminder emails (optional)
RESEND_API_KEY=
RESEND_FROM=

# Optional: token-gate the stale-turn cron sweep
CRON_SECRET=
